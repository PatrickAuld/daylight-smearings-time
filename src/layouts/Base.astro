---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Class applied to <body> so each page can theme itself globally. */
  bodyClass?: string;
}
const { title, description, bodyClass = '' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Public+Sans:ital,wght@0,300..800;1,300..800&family=IBM+Plex+Mono:wght@200;300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <slot name="head" />
</head>
<body class={bodyClass}>
  <slot />
</body>
</html>
